{
  "name": "guardo",
  "version": "1.2.0",
  "description": "Production-ready authentication engine for Node.js & Next.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/nadun-dilshan/guardo.git"
  },
  "homepage": "https://guardo.nadun.me",
  "bugs": {
    "url": "https://github.com/nadun-dilshan/guardo/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "require": "./dist/adapters/index.js",
      "import": "./dist/adapters/index.js"
    },
    "./notifiers": {
      "types": "./dist/notifiers/index.d.ts",
      "require": "./dist/notifiers/index.js",
      "import": "./dist/notifiers/index.js"
    },
    "./oauth": {
      "types": "./dist/oauth/index.d.ts",
      "require": "./dist/oauth/index.js",
      "import": "./dist/oauth/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "docs:dev": "npm run dev --workspace docs",
    "docs:build": "npm run build --workspace docs"
  },
  "workspaces": [
    "docs"
  ],
  "keywords": [
    "auth",
    "authentication",
    "jwt",
    "otp",
    "session",
    "nextjs",
    "express",
    "node",
    "security"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.12",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0",
    "ioredis": ">=5.0.0",
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "README.md"
  ]
}
