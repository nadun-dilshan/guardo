{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run typecheck)",
      "Bash(npm run docs:build)",
      "Bash(npm run dev)",
      "Bash(npm ci)",
      "Bash(npm ls:*)",
      "Bash(npm pack --dry-run)",
      "Bash(npx tsc --noEmit)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "ask": [
      "Bash(npm publish:*)",
      "Bash(git push:*)",
      "Bash(npm version:*)"
    ]
  }
}
